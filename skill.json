{
  "name": "cloudbypass-skill",
  "displayName": "穿云API - Cloudflare绕过技能",
  "version": "1.0.0",
  "description": "穿云API的OpenClaw技能实现，用于绕过Cloudflare 5秒盾、JavaScript质询、Turnstile验证等反爬虫保护，支持V1和V2两种模式。",
  "author": "Cloudbypass",
  "homepage": "https://www.cloudbypass.com/",
  "repository": {
    "type": "git",
    "url": "https://github.com/cloudbypass/cloudbypass-skill"
  },
  "keywords": [
    "cloudbypass",
    "cloudflare",
    "anti-crawl",
    "bypass",
    "proxy",
    "api",
    "turnstile",
    "javascript-challenge",
    "waf"
  ],
  "category": "web-scraping",
  "tags": [
    "cloudflare",
    "bypass",
    "proxy",
    "api"
  ],
  "icon": "https://www.cloudbypass.com/favicon.ico",
  "engines": {
    "node": ">=14.0.0"
  },
  "main": "scripts/cloudbypass_request.js",
  "files": [
    "scripts/cloudbypass_request.js",
    "skill.json",
    "SKILL.md"
  ],
  "config": {
    "apiKey": {
      "type": "string",
      "required": true,
      "description": "穿云API密钥，从控制台 https://console.cloudbypass.com/#/ 获取",
      "env": "CLOUDBYPASS_APIKEY"
    },
    "proxy": {
      "type": "string",
      "required": false,
      "description": "代理地址（V2模式必填），格式：http://proxy:port 或 socks5://proxy:port",
      "env": "CLOUDBYPASS_PROXY"
    },
    "mode": {
      "type": "string",
      "required": false,
      "default": "v1",
      "description": "API模式：v1（简单请求）或 v2（复杂会话）",
      "enum": ["v1", "v2"]
    },
    "part": {
      "type": "string",
      "required": false,
      "default": "0",
      "description": "会话分区标识（Part模式使用）",
      "env": "CLOUDBYPASS_PART"
    },
    "sitekey": {
      "type": "string",
      "required": false,
      "description": "Turnstile验证的sitekey",
      "env": "CLOUDBYPASS_SITEKEY"
    },
    "timeout": {
      "type": "number",
      "required": false,
      "default": 65000,
      "description": "请求超时时间（毫秒）"
    }
  },
  "capabilities": [
    "bypass-cloudflare",
    "bypass-turnstile",
    "bypass-javascript-challenge",
    "web-scraping",
    "proxy-request"
  ],
  "examples": [
    {
      "name": "V1模式 - 简单请求",
      "description": "使用V1模式访问受Cloudflare保护的网站",
      "code": "await skill.request({ url: 'https://opensea.io/category/memberships', method: 'GET' })"
    },
    {
      "name": "V2模式 - 复杂会话",
      "description": "使用V2模式处理需要会话的请求",
      "code": "await skill.request({ url: 'https://etherscan.io/accounts/label/lido', method: 'GET', mode: 'v2' })"
    }
  ],
  "documentation": {
    "api": "https://docs.cloudbypass.com/api-quick-reference.md",
    "tutorial": "https://www.cloudbypass.com/help/",
    "console": "https://console.cloudbypass.com/#/"
  },
  "license": "MIT"
}
